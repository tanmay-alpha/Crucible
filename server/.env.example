# Crucible Server Environment Variables Configuration Template
# Copy this file to .env and adjust values for your environment.

# Database URL (SQLite for local dev, PostgreSQL for production)
# SQLite: sqlite+aiosqlite:///./crucible.db
# Postgres (Supabase): postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./crucible.db

# Authentication Secret Key (JWT Token signing key - minimum 32 characters in production)
CRUCIBLE_SECRET_KEY=dev-secret-key-change-in-production-please-use-a-real-secret

# Master API Key for protected endpoints (X-API-Key header)
CRUCIBLE_API_KEY=crucible-development-api-key

# Allowed CORS origins (comma-separated URLs)
CRUCIBLE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://crucible-ai.vercel.app

# Server Logging Level (DEBUG, INFO, WARNING, ERROR)
CRUCIBLE_LOG_LEVEL=INFO
