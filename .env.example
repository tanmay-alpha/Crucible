# =============================================================================
# ONNX Inference Engine Production-Ready Configuration (.env.example)
# =============================================================================
# Copy this file to .env and configure values for your environment.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENVIRONMENT=development
APP_NAME="ONNX Inference Engine"
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
PYTHONUNBUFFERED=1
TZ=UTC

# ---------------------------------------------------------------------------
# Database (PostgreSQL / Supabase Transaction Pooler)
# ---------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres.wvddbvymctnrqwvryqka:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Set DB_STATEMENT_CACHE_SIZE=0 when using Supabase / PgBouncer transaction pooler
DB_STATEMENT_CACHE_SIZE=0

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Generate a secure key in production: openssl rand -hex 32
CRUCIBLE_SECRET_KEY=change-this-to-a-secure-random-32-character-secret-in-production
CRUCIBLE_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
CRUCIBLE_API_KEY=crucible-development-api-key
CRUCIBLE_API_KEY_PREFIX=cr_

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
CRUCIBLE_MODEL_DIR=/tmp/models
INFERENCE_TIMEOUT_SEC=60

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CRUCIBLE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
CRUCIBLE_LOG_LEVEL=INFO
CRUCIBLE_LOG_FORMAT=console

# ---------------------------------------------------------------------------
# Model Storage
# ---------------------------------------------------------------------------
MODEL_STORAGE_BACKEND=local
LOCAL_MODEL_DIR=/tmp/models

# ---------------------------------------------------------------------------
# ONNX Runtime
# ---------------------------------------------------------------------------
ONNX_EXECUTION_PROVIDER=CPUExecutionProvider
ONNX_NUM_THREADS=4

# ---------------------------------------------------------------------------
# Inference Engine
# ---------------------------------------------------------------------------
DEFAULT_INFERENCE_ENGINE=crucible-cpp
MAX_INFERENCE_BATCH_SIZE=100
MAX_INPUT_ELEMENTS=50000000

# ---------------------------------------------------------------------------
# Machine Learning & Training
# ---------------------------------------------------------------------------
CRUCIBLE_TRAIN_DATA=data/raw/creditcard.csv
CRUCIBLE_MODEL_OUTPUT=models/fraud_model.onnx

# ---------------------------------------------------------------------------
# Fraud Detection
# ---------------------------------------------------------------------------
FRAUD_HIGH_RISK_THRESHOLD=0.70
FRAUD_CRITICAL_RISK_THRESHOLD=0.90

# ---------------------------------------------------------------------------
# Upload Limits
# ---------------------------------------------------------------------------
MAX_UPLOAD_BYTES=209715200
MAX_REQUEST_BODY_BYTES=10485760

# ---------------------------------------------------------------------------
# Docker (Local Development Only)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=crucible_dev_password
GRAFANA_PASSWORD=admin

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=aws-0-ap-northeast-1.pooler.supabase.com
POSTGRES_PORT=6543

# ---------------------------------------------------------------------------
# Supabase Metadata
# ---------------------------------------------------------------------------
SUPABASE_PROJECT_ID=wvddbvymctnrqwvryqka
SUPABASE_URL=https://wvddbvymctnrqwvryqka.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
WEBHOOK_TIMEOUT_SEC=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_MAX_FAILURES=5

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics

# ---------------------------------------------------------------------------
# Prometheus
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_PORT=3000

# ---------------------------------------------------------------------------
# Future Redis Support
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_TTL_SEC=3600

# ---------------------------------------------------------------------------
# Future Email Support
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=
# EMAIL_FROM=alerts@crucible.ai

# ---------------------------------------------------------------------------
# Future Object Storage (S3 / Cloudflare R2)
# ---------------------------------------------------------------------------
# S3_BUCKET_NAME=crucible-models
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Future Queue Workers (Celery / RQ)
# ---------------------------------------------------------------------------
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2